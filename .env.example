# Docker image namespace and release tags
DOCKER_NAMESPACE=krobus00
VERSION=latest
HFT_VERSION=latest
WEB_VERSION=latest
STRATEGY_VERSION=latest
HFT_LOCAL_IMAGE=hft-service:local
WEB_LOCAL_IMAGE=krobot-web:local
STRATEGY_LOCAL_IMAGE=python-strategy:local

# Compose profiles used by Makefile targets.
# Add strategy when you want strategy containers in production compose.
PROFILES=infra app web

# Web image build-time browser API URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:9804/api/v1

# Published ports
MARKET_DATA_GATEWAY_PORT=9802
ORDER_ENGINE_HTTP_PORT=9800
ORDER_ENGINE_GRPC_PORT=9801
API_PORT=9804
WEB_PORT=3000
REDIS_PORT=6379
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222
POSTGRES_PORT=5432
STRATEGY_KROBOT01_PORT=19011
STRATEGY_KROBOT02_PORT=19012
STRATEGY_KROBOT03_PORT=19014
STRATEGY_AI_PORT=19013

# PostgreSQL
POSTGRES_DB=hft
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_MULTIPLE_DATABASES=market_data,order_engine,api,analytics

# Redis auth is optional. Leave empty to disable Redis password auth.
REDIS_PASSWORD=

# NATS auth is optional. Leave NATS_PASSWORD empty to disable NATS auth.
NATS_USER=hft
NATS_PASSWORD=

# Backup settings used by Makefile targets.
# Leave empty for production compose.yaml. Use compose-dev.yaml for dev infrastructure.
BACKUP_COMPOSE_FILE=
BACKUP_POSTGRES_IMAGE=postgres:16-alpine
# Set POSTGRES_HOST to back up a remote PostgreSQL server instead of a Compose service.
POSTGRES_HOST=
POSTGRES_SSLMODE=prefer
POSTGRES_SERVICE=postgresql
DATABASES=hft market_data order_engine api analytics
DB=hft
BACKUP_DIR=backups


# Local strategy runner helper.
STRATEGY_FILE=krobot01

# If REDIS_PASSWORD is set, update config.yml Redis DSNs:
# redis://:YOUR_REDIS_PASSWORD@redis:6379/0
# redis://:YOUR_REDIS_PASSWORD@redis:6379/1
# redis://:YOUR_REDIS_PASSWORD@redis:6379/2
#
# If NATS_PASSWORD is set, update config.yml and strategy/config.yml NATS URLs:
# nats://hft:YOUR_NATS_PASSWORD@nats:4222
