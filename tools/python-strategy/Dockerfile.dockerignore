# Keep the strategy image context small and free of local-only files.
**

!strategy/
!strategy/requirements.txt
!strategy/config.yml.example
!strategy/*.py
!strategy/core/
!strategy/core/*.py

strategy/config.yml
strategy/playground.py
strategy/standard_strategy_template.py
strategy/README.md
strategy/.venv/
strategy/**/__pycache__/
strategy/**/*.py[cod]
strategy/**/*.pyo
strategy/**/*.pyd
strategy/.pytest_cache/
strategy/.mypy_cache/
strategy/.ruff_cache/
strategy/.coverage
strategy/htmlcov/
