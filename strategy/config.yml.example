global:
  nats_url: nats://localhost:4222
  db_dsn: postgres://root:root@localhost:5432/market_data?sslmode=disable
  anthropic_base_url: https://api.minimax.io/anthropic
  anthropic_api_key: YOUR_API_KEY

krobot01:
  symbol: SOLUSDT
  interval: 1m

  exchange: tokocrypto
  market_type: spot
  position_side: BOTH
  user_id: paper-1
  source: python-krobot01
  strategy_id: python-krobot01-ema200-vwap-macd
  is_paper_trading: true

  kline_subject: KLINE.TOKOCRYPTO.>
  order_subject: order_engine.place_order
  queue_name: KLINE_STRATEGY_TOKOCRYPTO_KROBOT01

  order_type: LIMIT
  order_qty: 10
  order_symbol: SOLUSDT
  limit_slippage_pct: 0.02

  ema_period: 200
  vwap_window: 200
  macd_fast: 12
  macd_slow: 26
  macd_signal: 9

  historical_limit: 800
  cooldown_bars: 1
  take_profit_pct: 0.25
  stop_loss_pct: 0.15
  trailing_stop_pct: 0.12

template:
  name: TEMPLATE
  symbol: SOLUSDT
  interval: 1m
  historical_limit: 500

  exchange: tokocrypto
  market_type: spot
  position_side: BOTH
  user_id: paper-1
  source: python-template
  strategy_id: python-template
  is_paper_trading: true

  kline_subject: KLINE.TOKOCRYPTO.>
  order_subject: order_engine.place_order
  queue_name: KLINE_STRATEGY_TEMPLATE

  order_type: LIMIT
  order_qty: 10
  order_symbol: SOLUSDT
  limit_slippage_pct: 0.02

  cooldown_bars: 1

ai:
  name: AI-M2.7
  symbol: ETH_USDT.P
  interval: 1m
  historical_limit: 800

  exchange: binance
  market_type: futures
  position_side: ONE_WAY
  user_id: minimax-01
  source: python-ai-minimax-m2-7
  strategy_id: python-ai-minimax-m2-7-hybrid
  is_paper_trading: false

  kline_subject: KLINE.BINANCE.>
  order_subject: order_engine.place_order
  queue_name: KLINE_STRATEGY_BINANCE_AI

  order_type: MARKET
  order_qty: 10
  order_symbol: ETH_USDT.P
  limit_slippage_pct: 0.02

  # AI settings
  use_ai: true
  ai_model: MiniMax-M2.7
  ai_interval_bars: 1
  entry_confidence: 0.62
  override_confidence: 0.75

  # Indicator settings
  ema_fast: 50
  ema_slow: 200
  macd_fast: 12
  macd_slow: 26
  macd_signal: 9
  vwap_window: 120
  atr_n: 14
  rsi_period: 14

  # Risk controls
  take_profit_pct: 0.40
  stop_loss_pct: 0.25
  trailing_stop_pct: 0.20
  max_positions: 1
  max_hold_bars: 24
  cooldown_bars: 2
  enable_intrabar_risk_exit: true

breakout:
  name: BREAKOUT_PULLBACK
  symbol: SOL_USDT.P
  interval: 15m
  historical_limit: 800

  exchange: binance
  market_type: futures
  position_side: ONE_WAY
  user_id: paper-1
  source: python-breakout
  strategy_id: python-breakout-pullback
  is_paper_trading: true

  kline_subject: KLINE.BINANCE.>
  order_subject: order_engine.place_order
  queue_name: KLINE_STRATEGY_BINANCE_BREAKOUT

  order_type: MARKET
  order_qty: 2
  order_symbol: SOL_USDT.P
  limit_slippage_pct: 0.02

  ema_fast: 20
  ema_slow: 200
  atr_n: 14
  donchian_n: 20
  volume_window: 20
  volume_mult: 1.05
  min_atr_pct: 0.08
  max_distance_ema200_pct: 5.0
  pullback_wait_bars: 5
  pullback_tolerance_pct: 0.2
  stop_atr_mult: 1.5
  trail_atr_mult: 1.0
  take_profit_r: 1.5
  cooldown_bars: 2

trend_following_atr:
  name: TREND_FOLLOWING_ATR
  symbol: SOL_USDT.P
  interval: 15m
  historical_limit: 800

  exchange: binance
  market_type: futures
  position_side: ONE_WAY
  user_id: paper-1
  source: python-trend-following-atr
  strategy_id: python-trend-following-atr
  is_paper_trading: true

  kline_subject: KLINE.BINANCE.>
  order_subject: order_engine.place_order
  queue_name: KLINE_STRATEGY_BINANCE_TREND_FOLLOWING_ATR

  order_type: MARKET
  order_qty: 2
  order_symbol: SOL_USDT.P
  limit_slippage_pct: 0.02

  ema_fast: 20
  ema_mid: 50
  ema_slow: 200
  atr_n: 14
  rsi_n: 14
  use_rsi_filter: false
  rsi_min: 40
  rsi_max: 60
  use_volume_filter: false
  volume_window: 20
  volume_mult: 1.0
  pullback_tolerance_pct: 0.25
  atr_stop_mult: 2.0
  atr_trail_mult: 2.0
  take_profit_r: 0
  cooldown_bars: 1
