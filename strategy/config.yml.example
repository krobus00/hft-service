global:
  nats_url: nats://localhost:4222
  db_dsn: postgres://root:root@localhost:5432/market_data?sslmode=disable
  monitor_enabled: true
  monitor_host: 127.0.0.1
  proxy_host: https://llm.proxy
  api_key: YOUR_API_KEY
  max_tokens: 1200

krobot01:
  source: python-krobot01
  strategy_id: python-krobot01-ema200-vwap-macd
  order_subject: order_engine.place_order
  position_side: ONE_WAY # BOTH/ONE_WAY

  ema_period: 200
  vwap_window: 200
  macd_fast: 12
  macd_slow: 26
  macd_signal: 9

  historical_limit: 800

krobot02:
  name: KROBOT02_VWAP_VOLUME
  source: python-krobot02
  strategy_id: python-krobot02-vwap-volume
  order_subject: order_engine.place_order
  position_side: ONE_WAY # BOTH/ONE_WAY

  historical_limit: 800

  ema_period: 200
  vwap_window: 100
  volume_window: 20
  volume_mult: 1.15

krobot03:
  name: KROBOT03_EMA_BB_RSI
  source: python-krobot03
  strategy_id: python-krobot03-ema-bb-rsi
  order_subject: order_engine.place_order
  position_side: ONE_WAY # BOTH/ONE_WAY

  historical_limit: 800

  ema_fast: 21
  ema_slow: 50

  use_bollinger: true
  bb_window: 20
  bb_std_mult: 2.0

  use_atr_filter: false
  atr_n: 14
  atr_min_pct: 0.10

  use_stochastic: false
  stoch_k_period: 14
  stoch_d_period: 3
  stoch_low: 20
  stoch_high: 80

  rsi_period: 14
  rsi_buy_min: 52
  rsi_sell_max: 48

template:
  name: TEMPLATE
  source: python-template
  strategy_id: python-template
  order_subject: order_engine.place_order
  position_side: ONE_WAY # BOTH/ONE_WAY

  historical_limit: 500
  cooldown_bars: 1

ai:
  name: AI-M2.7
  historical_limit: 800

  source: python-ai-minimax-m2-7
  strategy_id: python-ai-minimax-m2-7-hybrid
  order_subject: order_engine.place_order
  position_side: ONE_WAY # BOTH/ONE_WAY

  # AI settings
  use_ai: true
  ai_model: MiniMax-M2.7
  ai_interval_bars: 1
  entry_confidence: 0.62
  override_confidence: 0.75

  # Indicator settings
  ema_fast: 50
  ema_slow: 200
  macd_fast: 12
  macd_slow: 26
  macd_signal: 9
  vwap_window: 120
  atr_n: 14
  rsi_period: 14

supertrend:
  name: SUPERTREND
  source: python-supertrend
  strategy_id: python-supertrend
  order_subject: order_engine.place_order

  position_side: ONE_WAY # BOTH/ONE_WAY
  
  # Supertrend indicator settings
  atr_period: 10
  multiplier: 3.0
  historical_limit: 600
