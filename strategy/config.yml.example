global:
  nats_url: nats://localhost:4222
  db_dsn: postgres://root:root@localhost:5432/market_data?sslmode=disable
  proxy_host: https://llm.proxy
  api_key: YOUR_API_KEY
  max_tokens: 1200
  risk_controls:
    cooldown_bars: 2
    sl_cooldown_bars: 3
    max_consecutive_stop_losses: 2
    sl_pause_bars: 10
    take_profit_pct: 0.25
    stop_loss_pct: 0.15
    trailing_stop_pct: 0.12
    max_hold_bars: 24
    max_positions: 1
    enable_intrabar_risk_exit: true

krobot01:
  exchange: tokocrypto
  market_type: spot
  position_side: BOTH
  user_id: paper-1
  source: python-krobot01
  strategy_id: python-krobot01-ema200-vwap-macd
  need_notification: true
  is_paper_trading: true

  kline_subject: KLINE.TOKOCRYPTO.>
  order_subject: order_engine.place_order
  queue_name: KLINE_STRATEGY_TOKOCRYPTO_KROBOT01

  order_type: LIMIT
  order_qty: 10
  limit_slippage_pct: 0.02

  ema_period: 200
  vwap_window: 200
  macd_fast: 12
  macd_slow: 26
  macd_signal: 9

  historical_limit: 800

krobot02:
  name: KROBOT02_VWAP_VOLUME
  exchange: tokocrypto
  market_type: spot
  position_side: BOTH
  user_id: paper-1
  source: python-krobot02
  strategy_id: python-krobot02-vwap-volume
  need_notification: true
  is_paper_trading: true

  kline_subject: KLINE.TOKOCRYPTO.>
  order_subject: order_engine.place_order
  queue_name: KLINE_STRATEGY_TOKOCRYPTO_KROBOT02

  order_type: LIMIT
  order_qty: 10
  limit_slippage_pct: 0.02

  historical_limit: 800

  ema_period: 200
  vwap_window: 100
  volume_window: 20
  volume_mult: 1.15


template:
  name: TEMPLATE
  historical_limit: 500

  exchange: tokocrypto
  market_type: spot
  position_side: BOTH
  user_id: paper-1
  source: python-template
  strategy_id: python-template
  need_notification: true
  is_paper_trading: true

  kline_subject: KLINE.TOKOCRYPTO.>
  order_subject: order_engine.place_order
  queue_name: KLINE_STRATEGY_TEMPLATE

  order_type: LIMIT
  order_qty: 10
  limit_slippage_pct: 0.02

  cooldown_bars: 1

ai:
  name: AI-M2.7
  historical_limit: 800

  exchange: binance
  market_type: futures
  position_side: ONE_WAY
  user_id: minimax-01
  source: python-ai-minimax-m2-7
  strategy_id: python-ai-minimax-m2-7-hybrid
  need_notification: true
  is_paper_trading: false

  kline_subject: KLINE.BINANCE.>
  order_subject: order_engine.place_order
  queue_name: KLINE_STRATEGY_BINANCE_AI

  order_type: MARKET
  order_qty: 10
  limit_slippage_pct: 0.02

  # AI settings
  use_ai: true
  ai_model: MiniMax-M2.7
  ai_interval_bars: 1
  entry_confidence: 0.62
  override_confidence: 0.75

  # Indicator settings
  ema_fast: 50
  ema_slow: 200
  macd_fast: 12
  macd_slow: 26
  macd_signal: 9
  vwap_window: 120
  atr_n: 14
  rsi_period: 14
