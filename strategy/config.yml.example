global:
  nats_url: nats://localhost:4222
  # If NATS auth is enabled:
  # nats_url: nats://hft:REPLACE_WITH_NATS_PASSWORD@localhost:4222
  nats_allow_reconnect: true
  nats_max_reconnect_attempts: -1
  nats_reconnect_time_wait_sec: 2
  nats_connect_timeout_sec: 5
  nats_ping_interval_sec: 30
  nats_max_outstanding_pings: 3
  db_dsn: postgres://root:root@localhost:5432/market_data?sslmode=disable
  db_pool_min_size: 1
  db_pool_max_size: 4
  strategy_config_refresh_interval_sec: 10
  message_queue_size: 1000
  redis_url: redis://localhost:6379/0
  # If Redis auth is enabled:
  # redis_url: redis://:REPLACE_WITH_REDIS_PASSWORD@localhost:6379/0
  redis_key_prefix: hft:strategy
  redis_state_ttl_sec: 86400
  redis_delete_removed_state: false
  proxy_host: https://llm.proxy
  api_key: YOUR_API_KEY

krobot01:
  monitor_enabled: true
  monitor_host: 127.0.0.1
  monitor_port: 19011

  ema_period: 200
  vwap_window: 200
  macd_fast: 12
  macd_slow: 26
  macd_signal: 9

  historical_limit: 800

krobot02:
  name: KROBOT02_VWAP_VOLUME
  monitor_enabled: true
  monitor_host: 127.0.0.1
  monitor_port: 19012

  historical_limit: 800

  ema_period: 200
  vwap_window: 100
  volume_window: 20
  volume_mult: 1.15

krobot03:
  name: KROBOT03_EMA_BB_RSI
  monitor_enabled: true
  monitor_host: 127.0.0.1
  monitor_port: 19013

  historical_limit: 800

  ema_fast: 21
  ema_slow: 50

  use_bollinger: true
  bb_window: 20
  bb_std_mult: 2.0

  use_atr_filter: false
  atr_n: 14
  atr_min_pct: 0.10

  use_stochastic: false
  stoch_k_period: 14
  stoch_d_period: 3
  stoch_low: 20
  stoch_high: 80

  rsi_period: 14
  rsi_buy_min: 52
  rsi_sell_max: 48

template:
  name: TEMPLATE
  monitor_enabled: true
  monitor_host: 127.0.0.1
  monitor_port: 19014

  historical_limit: 500
  cooldown_bars: 1

ai:
  name: AI-M2.7
  monitor_enabled: true
  monitor_host: 127.0.0.1
  monitor_port: 19015
  historical_limit: 800

  # AI settings
  use_ai: true
  ai_model: MiniMax-M2.7
  ai_interval_bars: 1
  entry_confidence: 0.62
  override_confidence: 0.75

  # Indicator settings
  ema_fast: 50
  ema_slow: 200
  macd_fast: 12
  macd_slow: 26
  macd_signal: 9
  vwap_window: 120
  atr_n: 14
  rsi_period: 14

supertrend:
  name: SUPERTREND
  monitor_enabled: true
  monitor_host: 127.0.0.1
  monitor_port: 19016
  
  # Supertrend indicator settings
  atr_period: 10
  multiplier: 3.0
  historical_limit: 600

capital_guard:
  name: CAPITAL_GUARD
  monitor_enabled: true
  monitor_host: 127.0.0.1
  monitor_port: 19017

  historical_limit: 1000

  ema_fast: 21
  ema_slow: 55
  ema_trend: 200
  vwap_window: 120
  volume_window: 30
  volume_mult: 1.10

  atr_n: 14
  atr_min_pct: 0.05
  atr_max_pct: 1.25
  max_bar_range_pct: 1.50

  rsi_period: 14
  rsi_long_min: 52
  rsi_long_max: 72
  rsi_short_min: 28
  rsi_short_max: 48
