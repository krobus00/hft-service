env: development
log:
  show_caller: false
  log_level: debug
graceful_shutdown_timeout: 30s
api_keys:
  - name: order-engine-client-a
    key: REPLACE_WITH_SECURE_API_KEY_A
    active: true
    expired_at: 2099-12-31T23:59:59Z
  - name: order-engine-client-b
    key: REPLACE_WITH_SECURE_API_KEY_B
    active: false
    expired_at: 2099-12-31T23:59:59Z
dashboard_auth:
  issuer: hft-dashboard
  token_secret: REPLACE_WITH_DASHBOARD_SECRET
  access_token_ttl: 15m
  refresh_token_ttl: 168h
port:
  market_data_gateway_grpc: 9802
  # Optional. Use market-data-gateway:9802 in Docker Compose or localhost:9802 for local processes.
  market_data_gateway_grpc_address: localhost:9802
  order_engine_gateway_grpc: 9800
  order_engine_gateway_http: 9801
  api_http: 9804
exchanges:
  binance:
    accounts:
      user-a:
        api_key: "user-a api key"
        api_secret: "user-a api secret"
      user-b:
        api_key: "user-b api key"
        api_secret: "user-b api secret"
  tokocrypto:
    accounts:
      user-a:
        api_key: "user-a api key"
        api_secret: "user-a api secret"
      user-b:
        api_key: "user-b api key"
        api_secret: "user-b api secret"
nats_jetstream:
  url: "nats://nats:4222"
  # If NATS_PASSWORD is set in Docker Compose, use:
  # url: "nats://hft:REPLACE_WITH_NATS_PASSWORD@nats:4222"
  max_retries: 5
  reconnect_factor: 2.0
  min_jitter: 100ms
  max_jitter: 1s
  timeout_handler:
    insert_kline: 5s
    place_order: 5s
    grid_strategy: 5s
    notification_alert: 5s
notification:
  discord_webhook_url: ""
database:
  market_data:
    dsn: "postgres://root:root@postgresql:5432/market_data?sslmode=disable"
    ping_interval: 5s
    reconnect_factor: 2.0
    min_jitter: 100ms
    max_jitter: 1s
    max_retry: 5
    max_idle_conns: 10
    max_active_conns: 100
    max_conn_lifetime: 1h
  order_engine:
    dsn: "postgres://root:root@postgresql:5432/order_engine?sslmode=disable"
    ping_interval: 5s
    reconnect_factor: 2.0
    min_jitter: 100ms
    max_jitter: 1s
    max_retry: 5
    max_idle_conns: 10
    max_active_conns: 100
    max_conn_lifetime: 1h
  api:
    dsn: "postgres://root:root@postgresql:5432/api?sslmode=disable"
    ping_interval: 5s
    reconnect_factor: 2.0
    min_jitter: 100ms
    max_jitter: 1s
    max_retry: 5
    max_idle_conns: 10
    max_active_conns: 100
    max_conn_lifetime: 1h
redis:
  api:
    cache_dsn: "redis://redis:6379/2"
    # If REDIS_PASSWORD is set in Docker Compose, use:
    # cache_dsn: "redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379/2"
    default_cache_duration: 5m
    max_retry: 5
    max_idle_conns: 10
    max_active_conns: 100
    max_conn_lifetime: 1h
  market_data:
    cache_dsn: "redis://redis:6379/0"
    # If REDIS_PASSWORD is set in Docker Compose, use:
    # cache_dsn: "redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379/0"
    default_cache_duration: 5m
    max_retry: 5
    max_idle_conns: 10
    max_active_conns: 100
    max_conn_lifetime: 1h
  strategy:
    cache_dsn: "redis://redis:6379/1"
    # If REDIS_PASSWORD is set in Docker Compose, use:
    # cache_dsn: "redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379/1"
    default_cache_duration: 5m
    max_retry: 5
    max_idle_conns: 10
    max_active_conns: 100
    max_conn_lifetime: 1h
